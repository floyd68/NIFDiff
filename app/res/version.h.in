// version.h - NIFDiff's single version source.
//
// Update these values manually (or through a release agent) when preparing a
// release. CMake copies this file to generated/version.h so both C++ and the
// Windows resource compiler consume the same version.
//
// Included by C++ (app shell title bar) AND by the resource compiler
// (NIFDiff.rc's VERSIONINFO), so it must stay preprocessor-only: no types,
// no namespaces, plain #defines.
#pragma once

#define NIFDIFF_VERSION_MAJOR    1
#define NIFDIFF_VERSION_MINOR    0
#define NIFDIFF_VERSION_REVISION 156

#define NIFDIFF_VERSION_STRING  "1.0.156"
#define NIFDIFF_VERSION_WSTR   L"1.0.156"

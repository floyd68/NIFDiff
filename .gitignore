# Build results
[Dd]ebug/
[Rr]elease/
build/
build*/
x64/
x86/
bin/
obj/
out/
[Ll]og/
[Ll]ogs/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual C++ cache/intermediate files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
*.ilk
*.obj
